<!DOCTYPE html>
{# GENERATED FILE — do not edit by hand. Source: docs/_templates/commands.html.j2 #}
{# Regenerate with: python scripts/gen_docs.py #}
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Command reference — aikido</title>
<meta name="description" content="Full reference for all {{ commands | length }} aikido CLI commands and their options. Generated from the live CLI.">
<link rel="stylesheet" href="style.css">
</head>
<body>
<nav class="nav">
  <a class="brand" href="index.html"><span class="mark">合</span> aikido</a>
  <div class="links">
    <a href="getting-started.html">Getting started</a>
    <a href="commands.html" class="active">Commands</a>
    <a href="concepts.html">Concepts</a>
    <a href="https://github.com/edwardmonteiro/aikido">GitHub</a>
    <a href="#" id="theme-toggle" title="Toggle theme">◐</a>
  </div>
</nav>

<main class="wrap">
  <h1>Command reference</h1>
  <p class="lead">All {{ commands | length }} commands, generated from the live CLI. Options use Typer conventions — underscores become hyphens (<code>--focus-area</code>), and booleans get a <code>--no-</code> negation (<code>--no-git</code>).</p>
  <p class="muted small">Generated by <code>scripts/gen_docs.py</code> — edit <code>docs/commands.meta.json</code> or the template, not this file.</p>

  <section>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Command</th><th>What it does</th></tr></thead>
        <tbody>
        {% for c in commands %}
          <tr><td><a href="#{{ c.name }}"><code>{{ c.name }}</code></a></td><td>{{ c.summary }}</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  {% for c in commands %}
  <section id="{{ c.name }}">
    <h2><code>aikido {{ c.name }}</code></h2>
    <p>{{ c.summary }}</p>
    {% if c.examples %}
    <pre><code>{% for ex in c.examples %}<span class="tok-p">$</span> {{ ex }}
{% endfor %}</code></pre>
    {% endif %}
    {% if c.params %}
    <div class="table-wrap"><table>
      <thead><tr><th>{{ "Argument / Option" }}</th><th>Default</th><th>Description</th></tr></thead>
      <tbody>
      {% for p in c.params %}
        <tr>
          <td><code>{{ p.display }}</code>{% if p.required %} <span class="muted small">(required)</span>{% endif %}</td>
          <td>{% if p.default %}<code>{{ p.default }}</code>{% else %}—{% endif %}</td>
          <td>{{ p.desc }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table></div>
    {% endif %}
    {% if c.note %}
    <div class="note">{{ c.note }}</div>
    {% endif %}
  </section>
  {% endfor %}
</main>

<footer>
  <div class="wrap">
    <span>aikido — AI-native knowledge &amp; decision operations. MIT licensed.</span>
    <span><a href="https://github.com/edwardmonteiro/aikido">github.com/edwardmonteiro/aikido</a></span>
  </div>
</footer>

<script>
  (function () {
    var key = "aikido-theme";
    var root = document.documentElement;
    var saved = localStorage.getItem(key);
    if (saved) root.setAttribute("data-theme", saved);
    var btn = document.getElementById("theme-toggle");
    if (btn) btn.addEventListener("click", function (e) {
      e.preventDefault();
      var cur = root.getAttribute("data-theme");
      var isDark = cur ? cur === "dark"
        : window.matchMedia("(prefers-color-scheme: dark)").matches;
      var next = isDark ? "light" : "dark";
      root.setAttribute("data-theme", next);
      localStorage.setItem(key, next);
    });
  })();
</script>
</body>
</html>
